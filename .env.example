# ============================================
# WhatsApp IPO Stock Screening Bot
# Environment Configuration
# ============================================

# --- Twilio WhatsApp Configuration ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Server Configuration ---
# Public URL where your server is accessible (required for Excel file attachments)
# For development with ngrok: https://your-ngrok-id.ngrok-free.app
# For production: https://your-domain.com
BASE_URL=http://localhost:8000

# Server host and port
HOST=0.0.0.0
PORT=8000

# --- Database ---
DATABASE_URL=sqlite:///./db/stock_screener.db

# --- Processing ---
# Number of parallel workers for stock scanning
MAX_WORKERS=10

# Delay between yfinance API calls (seconds) to avoid throttling
API_CALL_DELAY=0.5

# Maximum retries for failed API calls
MAX_RETRIES=3

# --- Cache ---
# Hours before refreshing NSE equity master list
CACHE_TTL_HOURS=24

# --- Logging ---
LOG_LEVEL=INFO
